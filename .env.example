# Copie este arquivo para ".env" e preencha com suas chaves reais.
# NUNCA suba o arquivo ".env" (com as chaves de verdade) para o GitHub.

# Chave de API da OpenAI (platform.openai.com -> API keys)
OPENAI_API_KEY=coloque_sua_chave_openai_aqui

# Access Token do Mercado Pago (painel de desenvolvedores -> suas integrações -> credenciais de produção)
MP_ACCESS_TOKEN=coloque_seu_access_token_mercadopago_aqui

# Chave secreta do webhook do Mercado Pago (aparece quando você configura a notificação no painel)
MP_WEBHOOK_SECRET=coloque_a_chave_secreta_do_webhook_aqui

# URL pública onde o app vai ficar hospedado (ex: https://photopro.onrender.com)
# É usada para montar a notification_url do Mercado Pago e as back_urls do checkout.
PUBLIC_URL=https://SEU-APP.onrender.com

# Porta do servidor (Render define isso automaticamente, pode deixar como está)
PORT=3000

# Preço da foto em reais
PRICE_BRL=9.90
